# Ignore temporary logs produced during development and troubleshooting
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Ignore installed packages and generated build output
node_modules
dist
dist-ssr
*.local

# Ignore local editor and operating system files that should not be shared
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
